# ── Core ─────────────────────────────────────────────────────────────────────
ENV=development                     # development | paper | production
LOG_LEVEL=INFO

# ── Broker: Dhan (Primary) ───────────────────────────────────────────────────
DHAN_CLIENT_ID=your_client_id
DHAN_ACCESS_TOKEN=your_access_token

# ── Broker: Shoonya (Fallback) ───────────────────────────────────────────────
SHOONYA_USER=your_user_id
SHOONYA_PASSWORD=your_password
SHOONYA_TOTP_SECRET=your_totp_secret
SHOONYA_VENDOR_CODE=your_vendor_code
SHOONYA_API_SECRET=your_api_secret
SHOONYA_IMEI=your_imei

# ── LLM: DeepSeek (Primary Agent Model) ─────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── LLM: Gemini (Monitoring + Fast Agents) ───────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── LLM: OpenAI (Fallback) ───────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ── Data ─────────────────────────────────────────────────────────────────────
SCREENER_SESSION_COOKIE=your_screener_cookie   # optional, for fundamentals

# ── Storage ──────────────────────────────────────────────────────────────────
DUCKDB_PATH=./data/storage/fund.duckdb
PARQUET_DIR=./data/storage/parquet

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Alerts ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
ALERT_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password

# ── Dashboard API ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change_this_in_production_min_32_chars

# ── Capital ───────────────────────────────────────────────────────────────────
INITIAL_CAPITAL=100000             # ₹1,00,000 — start small
PAPER_TRADING=true                 # Set false only when ready for live
