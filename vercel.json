{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "api/**",
          "data/storage/supabase_db.py",
          "risk/limits.py",
          "risk/kill_switch.py",
          "risk/__init__.py",
          "config/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.py" }
  ]
}
