{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "data/**|risk/**|monitoring/**|config/**|strategies/**|agents/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ]
}
