{
  "version": 2,
  "alias": ["luffy-labs.vercel.app"],
  "builds": [
    {
      "src": "dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "maxDuration": 60,
        "includeFiles": [
          "api/**",
          "agents/**",
          "data/storage/supabase_db.py",
          "data/storage/__init__.py",
          "risk/limits.py",
          "risk/kill_switch.py",
          "risk/__init__.py",
          "config/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
